<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.cocoindex.daemon</string>
	<key>Program</key>
	<string>/usr/local/bin/coco</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/coco</string>
		<string>daemon</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/var/log/coco-daemon.log</string>
	<key>StandardErrorPath</key>
	<string>/var/log/coco-daemon.err</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>COCOINDEX_REPO_ROOT</key>
		<string>$HOME/.cocoindex_code</string>
	</dict>
	<key>ThrottleInterval</key>
	<integer>10</integer>
	<key>Restart</key>
	<integer>1</integer>
</dict>
</plist>
